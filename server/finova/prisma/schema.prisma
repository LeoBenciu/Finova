generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int               @id @default(autoincrement())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  email               String            @unique
  role                Role              @default(ADMIN)
  hashPassword        String
  name                String
  phoneNumber         String
  accountingCompanyId Int
  accoutingCompany    AccountingCompany @relation(fields: [accountingCompanyId], references: [id])

  @@map("Users")
}

model Document {
  id              Int            @id @default(autoincrement())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  name            String
  type            String
  path            String
  status          DocumentStatus @default(PENDING)
  clientcompanyId Int
  clientCompany   ClientCompany  @relation(fields: [clientcompanyId], references: [id])
  processedData   ProcessedData?
  rpaActions      RpaAction[]

  @@map("Documents")
}

model ProcessedData {
  id              Int            @id @default(autoincrement())
  fileId          Int            @unique
  document        Document       @relation(fields: [fileId], references: [id])
  extractedText   String?
  extractedFields Json
  status          DocumentStatus @default(COMPLETED)
}

model RpaAction {
  id              Int             @id @default(autoincrement())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  documentId      Int
  document        Document        @relation(fields: [documentId], references: [id])
  clientCompanyId Int
  clientCompany   ClientCompany   @relation(fields: [clientCompanyId], references: [id])
  actionType      RpaActionType
  status          RpaActionStatus @default(PENDING)
  result          Json? // For storing error messages, success details, etc.
  triggeredBy     Int? // User ID who triggered the action (could be null if automated)

  @@map("RpaActions")
}

model ClientCompany {
  id                Int                 @id @default(autoincrement())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  name              String
  ein               String              @unique
  accountingClients AccountingClients[]
  documents         Document[]
  rpaActions        RpaAction[]
}

model AccountingCompany {
  id                Int                 @id @default(autoincrement())
  createAt          DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  name              String
  ein               String              @unique
  users             User[]
  accountingClients AccountingClients[]
}

model AccountingClients {
  accountingCompanyId Int
  clientCompanyId     Int
  accountingCompany   AccountingCompany @relation(fields: [accountingCompanyId], references: [id])
  clientCompany       ClientCompany     @relation(fields: [clientCompanyId], references: [id])
  createdAt           DateTime          @default(now())

  @@id([accountingCompanyId, clientCompanyId])
}

enum Role {
  USER
  ADMIN
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RpaActionType {
  DATA_ENTRY
  VALIDATION
  CORRECTION
  OTHER
}

enum RpaActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELED
}
